---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { site } from '../content/site';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  noindex?: boolean;
  currentPath?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = site.title,
  description = site.description,
  canonicalPath = Astro.url.pathname,
  image = '/og.png',
  noindex = false,
  currentPath = Astro.url.pathname,
  structuredData,
} = Astro.props;
const canonical = new URL(canonicalPath, site.url);
const socialImage = new URL(image, site.url);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#fafaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e110f" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/icons/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/icons/icon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Koru — writing memory for your Mac" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <title>{title}</title>
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Navigation currentPath={currentPath} />
    <main id="main-content"><slot /></main>
    <Footer />
  </body>
</html>
