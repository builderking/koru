---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroDemo from '../components/HeroDemo.astro';
import FaqList from '../components/FaqList.astro';
import DownloadButton from '../components/DownloadButton.astro';
import { site, download } from '../content/site';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Koru',
    url: site.url,
    description: site.description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Koru',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'macOS 13.0 or later',
    description: site.description,
    url: site.url,
    downloadUrl: new URL(download.page, site.url).href,
    isAccessibleForFree: true,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    author: { '@type': 'Organization', name: site.company, url: site.companyUrl },
  },
];

const features = [
  {
    title: 'Exact tags, right where you type',
    body: 'Give saved text one or more trigger tags of 3–64 characters. Type a complete tag anywhere in your writing and Koru opens beside the caret.',
    icon: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>',
  },
  {
    title: 'Save without switching apps',
    body: 'Select text you got right, save the content, and add the trigger tags you want. There is no title or separate item type to manage.',
    icon: '<path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1Z"/>',
  },
  {
    title: 'Clipboard, on your terms',
    body: 'Type clp anywhere to browse recent copies. Clipboard history is off until you turn it on, kept briefly, and stored encrypted.',
    icon: '<rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4a3 3 0 0 1 6 0"/><path d="M9 11h6M9 15h4"/>',
  },
  {
    title: 'Search when you forget the tag',
    body: 'Open Koru with the global shortcut and search saved content or tags. The shortcut stays available when an app limits typed matching.',
    icon: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h5"/><path d="M15.5 15.5 17 17"/>',
  },
  {
    title: 'Complete tags only',
    body: 'Koru waits for a complete assigned tag — da stays quiet for a tag named dav — then lets you choose before replacing only that tag.',
    icon: '<path d="m13 3-9 11h7l-1 7 9-11h-7l1-7Z"/>',
  },
  {
    title: 'Works where you write',
    body: 'Email, docs, browsers, editors, terminals. Where an app or macOS Secure Input limits matching or insertion, Koru falls back to the hotkey and copy.',
    icon: '<path d="M4 17V7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/><path d="M2 17h20v1a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-1Z"/>',
  },
];
---
<BaseLayout structuredData={structuredData}>
  <section class="hero">
    <div class="shell">
      <p class="hero-badge"><span class="dot" aria-hidden="true"></span>Free for macOS</p>
      <h1>Never rewrite what you already got right.</h1>
      <p class="lede">Koru remembers the text you choose to keep — replies, snippets, prompts, commands — and brings it back right where you're typing. All of it stays on your Mac.</p>
      <div class="actions">
        <DownloadButton large />
        <a class="button button-secondary button-large" href="#how-it-works">See how it works</a>
      </div>
      <p class="trust-line"><span>{download.price}</span><span>{download.requirement}</span><span>No account required</span></p>
    </div>
  </section>

  <HeroDemo />

  <section class="section" id="how-it-works">
    <div class="shell">
      <div class="section-intro">
        <p class="eyebrow">How it works</p>
        <h2>Save it once. Recall it anywhere.</h2>
        <p>Koru lives in your menu bar and stays out of the way until you call it — three deliberate steps, no context switch.</p>
      </div>
      <div class="steps">
        <article class="step">
          <h3>Save what's worth keeping</h3>
          <p>Select a sentence, reply, command, or prompt, save its content, and assign one or more trigger tags of 3–64 characters.</p>
        </article>
        <article class="step">
          <h3>Type a tag or use the shortcut</h3>
          <p>Type a complete assigned tag anywhere in your writing. Koru appears beside the caret. Use the global shortcut to search content and tags, or type <code>clp</code> anywhere for recent copies.</p>
        </article>
        <article class="step">
          <h3>Insert with intent</h3>
          <p>Pick a result and Koru inserts it exactly where you were typing. Nothing is ever pasted, replaced, or sent until you explicitly choose it.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="shell">
      <div class="section-intro">
        <p class="eyebrow">Features</p>
        <h2>One memory for everything you retype.</h2>
        <p>Permanent saved writing and temporary clipboard history, together in a single recall surface.</p>
      </div>
      <div class="card-grid">
        {features.map((feature) => (
          <article class="card">
            <div class="card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={feature.icon} />
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="privacy">
    <div class="shell split">
      <div class="section-intro left" style="margin-bottom:0">
        <p class="eyebrow">Private by design</p>
        <h2>Your writing never leaves your Mac.</h2>
        <p>Koru is a local app, not a cloud service. There's no account to create, no sync to trust, and no server reading what you write.</p>
        <div class="actions">
          <a class="button button-secondary" href="/privacy/">Read the privacy model</a>
        </div>
      </div>
      <ul class="check-list">
        <li>Everything is stored locally, encrypted at rest with a key in your Mac's Keychain.</li>
        <li>No analytics, tracking, or background network requests.</li>
        <li>Clipboard history stays off until you explicitly enable it — and expires on your schedule.</li>
        <li>Koru does not deliberately exclude password fields, but macOS Secure Input can prevent typed matching or replacement.</li>
        <li>Pause, Clipboard exclusions, export, clear, and delete-everything controls are always one click away.</li>
      </ul>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="shell">
      <div class="section-intro">
        <p class="eyebrow">FAQ</p>
        <h2>Questions, answered.</h2>
      </div>
      <FaqList />
      <div class="actions" style="justify-content:center">
        <a class="button button-secondary" href="/faq/">Read the full FAQ</a>
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="shell">
      <div class="cta-panel">
        <p class="eyebrow">Get Koru</p>
        <h2>Stop retyping. Start recalling.</h2>
        <p>Download Koru free and give your writing a memory. {download.requirement}, {download.architectures}.</p>
        <div class="actions">
          <DownloadButton large />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
