---
import { download } from '../content/site';

interface Props {
  large?: boolean;
  // When true, links to the artifact itself (download page); otherwise to /download/.
  direct?: boolean;
}
const { large = false, direct = false } = Astro.props;
const href = direct ? download.artifactUrl : download.page;
---
<a class:list={['button', 'button-primary', { 'button-large': large }]} href={href}>
  <svg class="apple-mark" viewBox="0 0 17 20" fill="currentColor" aria-hidden="true">
    <path d="M14.15 10.63c-.02-2.2 1.8-3.26 1.88-3.31-1.02-1.5-2.62-1.7-3.19-1.73-1.36-.14-2.65.8-3.34.8-.68 0-1.75-.78-2.88-.76-1.48.02-2.85.86-3.61 2.19-1.54 2.67-.39 6.62 1.11 8.79.73 1.06 1.6 2.25 2.75 2.21 1.1-.05 1.52-.71 2.86-.71 1.33 0 1.71.71 2.88.69 1.19-.02 1.94-1.08 2.67-2.14.84-1.23 1.18-2.42 1.2-2.48-.03-.01-2.31-.89-2.33-3.55zM11.95 3.99c.61-.74 1.02-1.76.9-2.79-.87.04-1.94.58-2.57 1.32-.56.65-1.06 1.7-.93 2.7.98.08 1.98-.5 2.6-1.23z" />
  </svg>
  <span>Download for macOS</span>
</a>
