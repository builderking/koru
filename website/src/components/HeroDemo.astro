<section class="hero-demo" aria-label="Product preview">
  <div class="shell">
    <div class="demo-stage">
      <figure style="margin:0" aria-labelledby="demo-caption">
        <div class="app-window" aria-hidden="true">
          <div class="window-bar">
            <span></span><span></span><span></span>
            <p class="window-title">New message</p>
          </div>
          <div class="window-body">
            <div class="ghost-line"></div>
            <div class="ghost-line short"></div>
            <div class="typed-row"><span>foll</span><span class="caret"></span></div>
          </div>
        </div>
        <div class="recall-panel" aria-hidden="true">
          <div class="search-row"><span>⌕&nbsp; “foll”</span><span class="count">3 matches</span></div>
          <div class="result selected">
            <span class="result-icon">S</span>
            <span><strong>Follow-up after intro call</strong><small>Saved text</small></span>
            <span class="key">↵</span>
          </div>
          <div class="result">
            <span class="result-icon">T</span>
            <span><strong>Client follow-up template</strong><small>Template · 3 fields</small></span>
            <span class="key">2</span>
          </div>
          <div class="result">
            <span class="result-icon">C</span>
            <span><strong>Recent clipboard</strong><small>Type clp to browse copies</small></span>
            <span class="key">3</span>
          </div>
        </div>
        <figcaption class="demo-caption" id="demo-caption">
          Type a fragment you remember. Koru shows matching saved items beside the caret — nothing is inserted until you choose.
        </figcaption>
      </figure>
    </div>
  </div>
</section>
