---
import { site } from '../content/site';
interface Props { currentPath?: string }
const { currentPath = '/' } = Astro.props;
const isCurrent = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<header class="site-header">
  <nav class="nav shell" aria-label="Primary navigation">
    <a class="wordmark" href="/" aria-label="Koru home">
      <span class="glyph" aria-hidden="true">K</span>
      <span>Koru</span>
    </a>
    <div class="nav-links">
      <a class="desktop-link" href="/#how-it-works">How it works</a>
      <a class="desktop-link" href="/docs/" aria-current={isCurrent('/docs/') ? 'page' : undefined}>Docs</a>
      <a href={site.repository}>GitHub</a>
      <a class="button button-primary" href="/download/" aria-current={isCurrent('/download/') ? 'page' : undefined}>Release status</a>
    </div>
  </nav>
</header>
